# ═══════════════════════════════════════════════════════════
# AI 电商商品图自动生成系统 · 配置文件
# 复制为 .env 并填入实际值
# ═══════════════════════════════════════════════════════════

# ── API 凭证 (必填) ──────────────────────────────────────
# OpenAI / OneAPI / NewAPI / OpenRouter 等兼容 API
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ── API 接入地址 ──────────────────────────────────────────
# 官方 OpenAI:  https://api.openai.com/v1
# OneAPI:       https://your-oneapi-host/v1
# OpenRouter:   https://openrouter.ai/api/v1
# VectorEngine: https://api.vectorengine.ai/v1
BASE_URL=https://api.openai.com/v1

# ── 模型名称 ──────────────────────────────────────────────
# 统一文本/视觉模型 (需具备 vision 能力, Stage1 读图必须)
MODEL_NAME=gpt-4o
# 可选: 分别指定视觉 / 文本模型 (留空回退到 MODEL_NAME)
VISION_MODEL=
TEXT_MODEL=
# 图像生成模型 (images.edit API)
IMAGE_MODEL=gpt-image-1
# 也可使用: gpt-image-2, gpt-image-2-all 等

# ── Web 服务 ──────────────────────────────────────────────
# 监听地址和端口
WEB_HOST=127.0.0.1
WEB_PORT=8000

# ── 输出 ──────────────────────────────────────────────────
# 产物根目录 (每个 SKU 在此目录下创建子文件夹)
OUTPUT_ROOT=output

# ── 性能 ──────────────────────────────────────────────────
# LLM 请求超时 (秒), 大上下文 Stage3 建议 ≥300
REQUEST_TIMEOUT=600
# 图片并发生成数 (同时生成几张图)
CONCURRENCY=4
# API 调用失败重试次数 (≥2)
MAX_RETRIES=3
# 重试退避基数 (秒), 第 n 次重试等待 base^(n-1) 秒
RETRY_BACKOFF=2.0

# ── 行为 ──────────────────────────────────────────────────
# 生成模式: full(全套14张) | hero(仅主图5张) | detail(仅详情9张) | lookbook(模特套图5张)
GENERATION_MODE=full
# 强制重新生成 (忽略所有缓存)  true/false
FORCE=false
# 启用 LLM 调用缓存 (避免重复花钱)  true/false
USE_PROMPT_CACHE=true

# ── 日志 ──────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
